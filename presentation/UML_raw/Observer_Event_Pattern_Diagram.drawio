        <mxCell id="Event" parent="pkg-eventbus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;spacing=8;" value="&lt;b&gt;Event&lt;/b&gt;&lt;hr&gt;- simulationTime_: SimulationTime&lt;br&gt;- type_: EventType&lt;br&gt;- sourceId_: MachineId&lt;br&gt;- message_: string&lt;hr&gt;+ simulationTime() const&lt;br&gt;+ type() const&lt;br&gt;+ sourceId() const&lt;br&gt;+ message() const" vertex="1">
