#include "../../include/model/Inventory.hpp"

#include <sstream>

namespace factory {

Inventory::Inventory() {
}

void Inventory::addIngredient(const Ingredient& ingredient) {
    const std::string& name = ingredient.getName();

    auto it = stock.find(name);

    if (it != stock.end()) {
        it->second.addAmount(ingredient.getAmount());
    } else {
        stock.insert({ name, ingredient });
    }
}

bool Inventory::hasIngredient(
    const std::string& name,
    double requiredAmount
) const {
    auto it = stock.find(name);

    if (it == stock.end()) {
        return false;
    }

    return it->second.getAmount() >= requiredAmount;
}

bool Inventory::useIngredient(
    const std::string& name,
    double amount
) {
    auto it = stock.find(name);

    if (it == stock.end()) {
        return false;
    }

    return it->second.consumeAmount(amount);
}

double Inventory::getAmount(const std::string& name) const {
    auto it = stock.find(name);

    if (it == stock.end()) {
        return 0.0;
    }

    return it->second.getAmount();
}

std::string Inventory::getStockInfo() const {
    std::ostringstream oss;

    if (stock.empty()) {
        oss << "Inventory is empty.\n";
        return oss.str();
    }

    oss << "===== Inventory Stock =====\n";

    for (const auto& pair : stock) {
        const Ingredient& ingredient = pair.second;

        oss << "- "
            << ingredient.getName()
            << ": "
            << ingredient.getAmount()
            << " "
            << ingredient.getUnit()
            << "\n";
    }

    return oss.str();
}

}