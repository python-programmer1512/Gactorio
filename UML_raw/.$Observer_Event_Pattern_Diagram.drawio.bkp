        <mxCell id="Factory" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;spacing=8;" value="&lt;b&gt;Factory&lt;/b&gt;&lt;hr&gt;- eventBus_: EventBus&lt;br&gt;- eventLog_: EventLogObserver&lt;br&gt;- statistics_: StatisticsObserver&lt;br&gt;- productionLines_: vector&amp;lt;ProductionLine&amp;gt;&lt;hr&gt;+ Factory()&lt;br&gt;+ addProductionLine(line)&lt;br&gt;+ eventLog() const&lt;br&gt;+ statistics() const&lt;hr&gt;&lt;i&gt;Owns bus and subscribers; wires line/machine publishers&lt;/i&gt;" vertex="1">
