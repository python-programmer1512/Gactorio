        <mxCell id="EventBus" parent="pkg-eventbus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;spacing=8;" value="&lt;b&gt;EventBus&lt;/b&gt;&lt;hr&gt;- observers_: vector&amp;lt;Observer*&amp;gt;&lt;hr&gt;+ subscribe(observer: Observer*)&lt;br&gt;+ publish(event: const Event&amp;amp;) const&lt;hr&gt;&lt;i&gt;Does not own observers&lt;/i&gt;" vertex="1">
