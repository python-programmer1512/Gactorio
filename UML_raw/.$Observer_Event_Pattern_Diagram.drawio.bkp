        </mxCell>
        <mxCell id="ProductionLine" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacing=8;" value="&lt;b&gt;ProductionLine&lt;/b&gt;&lt;hr&gt;- eventBus_: EventBus*&lt;hr&gt;+ setEventBus(eventBus)&lt;br&gt;+ enqueueProduct(product)&lt;hr&gt;&lt;i&gt;Publishes TaskEnqueued when a product is queued&lt;/i&gt;" vertex="1">
          <mxGeometry height="140" width="330" x="75" y="145" as="geometry" />
        </mxCell>
        <mxCell id="Machine" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacing=8;" value="&lt;b&gt;Machine&lt;/b&gt;&lt;hr&gt;- eventBus_: EventBus*&lt;hr&gt;+ setEventBus(eventBus)&lt;br&gt;+ assignTask(task)&lt;br&gt;+ pause() / resume()&lt;br&gt;+ advanceProduction(deltaTime)&lt;br&gt;+ advanceMaintenance(deltaTime)&lt;br&gt;- notify(type, message) const&lt;hr&gt;&lt;i&gt;Publishes task, step, product, repair, breakdown, and state events&lt;/i&gt;" vertex="1">
          <mxGeometry height="210" width="330" x="75" y="310" as="geometry" />
