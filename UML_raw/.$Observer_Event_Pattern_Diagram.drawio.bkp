        <mxCell id="FactoryWiring" parent="pkg-owner" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacing=8;" value="&lt;b&gt;Factory constructor wiring&lt;/b&gt;&lt;hr&gt;eventBus_.subscribe(&amp;amp;eventLog_)&lt;br&gt;eventBus_.subscribe(&amp;amp;statistics_)&lt;hr&gt;&lt;b&gt;Line wiring&lt;/b&gt;&lt;br&gt;line.setEventBus(&amp;amp;eventBus_)&lt;br&gt;machine.setEventBus(eventBus_)" vertex="1">
